# ==========================================
# Configuración para Producción - APP POS (VITE)
# ==========================================

# URL Absoluta del Backend Prod (Next.js)
# NOTA: En producción Vite no usa proxies, la URL debe apuntar directamente al backend real
VITE_API_BASE_URL=https://api.tudominio.com/api

# Intervalo local de intentos de Sync 
VITE_SYNC_INTERVAL_MS=180000

# Secreto de seguridad para el Endpoint de Pull/Push
# Debe hacer match exacto con el POS_SYNC_SECRET en el backend de Next.js
VITE_SYNC_SECRET=tu-clave-secreta-larga-y-segura-prod
VITE_POS_SYNC_SECRET=tu-clave-secreta-larga-y-segura-prod
