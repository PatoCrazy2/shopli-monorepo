# ==========================================
# Configuración para Producción - ADMIN BACKEND (NEXT.JS)
# ==========================================

# URL Absoluta de donde están alojados los reportes/dashboard
NEXTAUTH_URL="https://admin.tudominio.com"

# URL FrontEnd del POS para configurar los CORS de Seguridad de la API de Next.js
# Esto le dice a Next.js que solo acepte peticiones hechas por tu POS Real
POS_APP_URL="https://pos.tudominio.com"

# Claves criptográficas seguras (Generarlas con `openssl rand -base64 32`)
AUTH_SECRET="tu-auth-secret-super-largo-aqui"
NEXTAUTH_SECRET="tu-auth-secret-super-largo-aqui"

# URL de la Base de Datos Productiva (Neon/Postgres/Render)
# Requiere usar pgbouncer o pgmigration según corresponda en producción
DATABASE_URL="postgresql://user:pass@tu-huesped.aws.neon.tech/shopli_prod?sslmode=require"

# Secreto de Autenticación de las APIs del POS (Pull/Push)
# ESTE DEBE COINCIDIR EXACTAMENTE CON EL .env DEL POS FRONTEND
POS_SYNC_SECRET=tu-clave-secreta-larga-y-segura-prod
